{
  "routing": {
    "claudeTokenLimit": 50000,
    "geminiTokenLimit": 800000,
    "maxTotalSizeBytes": 10485760,
    "minFilesForTask": 3,
    "charsPerToken": 4
  },
  "gemini": {
    "bin": "gemini",
    "timeoutMs": 120000,
    "rateLimitMs": 1000
  },
  "codex": {
    "approvalMode": "suggest",
    "timeoutMs": 180000
  },
  "cache": {
    "ttlSeconds": 3600,
    "dir": null
  },
  "security": {
    "excludePatterns": [
      "*.secret", "*.key", "*.env", "*.password",
      "*.token", "*.pem", "*.p12", ".env*",
      "*.zip", "*.tar", "*.gz", "*.bin", "*.exe", "*.dmg"
    ],
    "blockedPaths": [
      "/etc/", "/usr/", "/bin/", "/sbin/", "/root/"
    ]
  },
  "debug": {
    "level": 0,
    "logDir": null
  }
}
